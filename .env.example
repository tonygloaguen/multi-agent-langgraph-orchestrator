# ── LLM API Keys ──────────────────────────────────────────────────────────────
# NE JAMAIS committer ce fichier avec de vraies clés.
# .env est exclu de Git par .gitignore.
ANTHROPIC_API_KEY=sk-ant-VOTRE_CLE_ICI
OPENAI_API_KEY=sk-VOTRE_CLE_ICI
GEMINI_API_KEY=VOTRE_CLE_ICI

# ── Modèles LLM ───────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-opus-4-6
CODEX_MODEL=codex-mini-latest
GEMINI_MODEL=gemini-2.0-flash

# ── Orchestrateur ─────────────────────────────────────────────────────────────
ORCHESTRATOR_MAX_REPAIR_LOOPS=2
ORCHESTRATOR_TASK_TIMEOUT=300
ORCHESTRATOR_CONTEXT_MAX_TOKENS=8000
GEMINI_FALLBACK_ENABLED=true
RTK_ENABLED=true
DEFAULT_REPO_PATH=.
GIT_AGENT_BRANCH_PREFIX=agent/
HANDOFFS_DIR=./orchestrator/handoffs
STATE_DIR=./orchestrator/state
LOGS_DIR=./logs

# ── Authentification API (RBAC) ───────────────────────────────────────────────
# AUTH_ENABLED=false désactive l'auth (UNIQUEMENT pour dev local, jamais en prod)
AUTH_ENABLED=true

# Générer avec : python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# IMPORTANT : utiliser des valeurs différentes pour chaque rôle et chaque env.
API_TOKEN_ADMIN=CHANGER-MOI-token-admin-32-chars-minimum
API_TOKEN_OPERATOR=CHANGER-MOI-token-operator-32-chars-minimum
API_TOKEN_READER=CHANGER-MOI-token-reader-32-chars-minimum

# ── CORS ──────────────────────────────────────────────────────────────────────
# Origines autorisées (virgule séparées). Ne jamais mettre * en production.
CORS_ALLOWED_ORIGINS=http://localhost:8080

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RUN=5/minute
RATE_LIMIT_DEFAULT=60/minute
